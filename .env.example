# ---------------------------------------------------------------------------
# Copy this file to .env.local (for local dev) and fill in real values.
# Never commit .env.local or any file containing real secrets.
# ---------------------------------------------------------------------------

# --- Database (Supabase PostgreSQL via Prisma) -----------------------------
# Pooled connection (used at runtime, e.g. Supabase's port 6543 pgbouncer URL)
DATABASE_URL="postgresql://postgres:password@db.xxxxxxxxxxxx.supabase.co:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma Migrate, e.g. port 5432)
DIRECT_URL="postgresql://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres"

# --- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="product-images"

# --- Clerk (Authentication) --------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/register"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Admin Access --------------------------------------------------------------
# Comma-separated list of emails allowed into /admin. A Clerk user whose
# publicMetadata.role is "admin" is also treated as an admin, so you can grant
# access either way (env whitelist for quick setup, Clerk metadata for teams
# managed entirely from the Clerk dashboard).
ADMIN_EMAILS="owner@example.com,manager@example.com"

# --- Stripe (Payments) --------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- App -----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
